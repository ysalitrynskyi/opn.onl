# ===========================================
# DOCKER COMPOSE ENVIRONMENT VARIABLES
# opn.onl - URL Shortener
# ===========================================
# Copy this file to .env and fill in your production values

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_DB=opn_onl

# ===========================================
# SECURITY
# ===========================================
# REQUIRED: generate a unique value with `openssl rand -base64 64`.
# This template intentionally leaves it empty; the backend refuses to start.
JWT_SECRET=

# Account deletion (disabled by default)
ENABLE_ACCOUNT_DELETION=false

# ===========================================
# URLS (Update with your domain)
# ===========================================
# Backend API URL (used by frontend)
BASE_URL=https://api.opn.onl
FRONTEND_URL=https://opn.onl

# Frontend build-time variables
VITE_API_URL=https://api.opn.onl
VITE_FRONTEND_URL=https://opn.onl

# Force HTTPS redirect (recommended: true in production)
FORCE_HTTPS=true

# Client identity behind the proxy chain (rate limiting + click analytics).
# Defaults are correct for the documented Cloudflare tunnel setup: proxy
# headers trusted, real client IP taken from CF-Connecting-IP (set
# authoritatively by Cloudflare; not spoofable through the edge).
# Set REAL_IP_HEADER empty if you deploy without Cloudflare.
TRUST_PROXY_HEADERS=true
REAL_IP_HEADER=cf-connecting-ip
TRUSTED_PROXY_HOPS=0

# ===========================================
# CLOUDFLARE TUNNEL
# ===========================================
# Get from Cloudflare Zero Trust dashboard:
# 1. Go to Zero Trust > Access > Tunnels
# 2. Create a tunnel
# 3. Copy the token
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ===========================================
# REDIS CACHE
# ===========================================
REDIS_CACHE_TTL=300

# ===========================================
# LOGGING
# ===========================================
RUST_LOG=info,tower_http=info

# ===========================================
# EMAIL (SMTP) - Optional but recommended
# ===========================================
# Required for: email verification, password reset, contact form
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=noreply@opn.onl
SMTP_FROM_NAME=opn.onl
ADMIN_EMAIL=admin@opn.onl

# SMTP encryption mode:
# - starttls: Use STARTTLS upgrade (default, port 587)
# - tls: Use implicit TLS/SSL (for port 465)
# - none: No encryption (NOT recommended)
SMTP_TLS=starttls

# ===========================================
# S3 BACKUP (Cloudflare R2) - Optional
# ===========================================
# Required for: automated database backups
BACKUP_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
BACKUP_S3_BUCKET=opn-backups
BACKUP_S3_ACCESS_KEY=your-r2-access-key
BACKUP_S3_SECRET_KEY=your-r2-secret-key
BACKUP_S3_REGION=auto

# ===========================================
# PERFORMANCE TUNING
# ===========================================
# Click event batching (reduce DB writes)
CLICK_BUFFER_SIZE=100
CLICK_FLUSH_INTERVAL=10

# ===========================================
# GEOIP (MaxMind) - Optional
# ===========================================
# For location analytics (country/city detection)
# Sign up for free: https://www.maxmind.com/en/geolite2/signup
# MAXMIND_ACCOUNT_ID=123456
# MAXMIND_LICENSE_KEY=your-license-key

# ===========================================
# DOCKER IMAGES (for Portainer deployment)
# ===========================================
# If using pre-built images instead of building in Portainer:
# BACKEND_IMAGE=ghcr.io/your-username/opn-backend:latest
# FRONTEND_IMAGE=ghcr.io/your-username/opn-frontend:latest

# ===========================================
# GOOGLE ANALYTICS - Optional (Runtime)
# ===========================================
# Add your Google Analytics 4 Measurement ID
# This is set at container runtime (not build time)
GA_ID=G-XXXXXXXXXX

# ===========================================
# LINK MANAGEMENT
# ===========================================
# Allow users to use custom aliases (default: true)
ENABLE_CUSTOM_ALIASES=true

# Allow reusing slugs from deleted links (default: false)
# When false, once a slug is used (even if deleted), it cannot be reused
ALLOW_DELETED_SLUG_REUSE=false

# Alias settings
MIN_ALIAS_LENGTH=5
MAX_ALIAS_LENGTH=25

# URL security (enabled by default)
ENABLE_URL_SANITIZATION=true

# Abuse guards on link destinations (both default: true — recommended for any
# public instance). See backend/.env.example for details.
#   BLOCK_DANGEROUS_FILE_EXTENSIONS — refuse links straight at executable/script
#     files (.hta, .exe, .msi, .jar, .apk, …), a common malware vector.
#   BLOCK_RAW_IP_URLS — refuse links whose host is a bare IP. Self-hosters who
#     shorten internal/LAN IPs can set this to false.
BLOCK_DANGEROUS_FILE_EXTENSIONS=true
BLOCK_RAW_IP_URLS=true

# Branded QR codes — brand colour, centre logo and SVG export on the
# /links/{id}/qr endpoint. Kill-switch only (default: true). When false the
# endpoint ignores all options and serves a plain black/white PNG.
ENABLE_QR_BRANDING=true

# Burn-after-reading — one-time / self-destruct links. Enabled by default
# (set =false to disable). A burn link permanently disables once it hits its cap;
# it stays a per-link opt-in, so nothing self-destructs unless you turn it on.
ENABLE_BURN_AFTER_READING=true

# Safe-link interstitial — optional "you're leaving to X — looks safe ✓" preview
# before redirecting, on links that opt in. Enabled by default (set =false to
# disable). Per-link opt-in, so normal links still redirect instantly.
ENABLE_SAFE_LINK_INTERSTITIAL=true

# Smart conditional routing — route one short link to different destinations by
# device / OS / country / language, with optional weighted A/B. Enabled by default
# (set =false to disable). Links with no rules fall back to their own URL.
ENABLE_CONDITIONAL_ROUTING=true

# Link-in-bio — public profile page at /@username aggregating a user's links.
# Enabled by default (set =false to disable); still requires each user to claim a
# username and turn their page on, so no profile is public until they opt in.
ENABLE_LINK_IN_BIO=true

# API keys — personal access tokens (opn_…) for the MCP server / API clients.
# Enabled by default (set =false to disable creation AND key authentication).
ENABLE_API_KEYS=true

# ===========================================
# PGADMIN (Optional database management UI)
# ===========================================
PGADMIN_EMAIL=admin@opn.onl
PGADMIN_PASSWORD=your-pgadmin-password

# ===========================================
# RATE LIMITING
# ===========================================

# Global email rate limit (prevents abuse/DDoS, controls costs)
# Maximum emails that can be sent per hour (default: 500)
EMAIL_RATE_LIMIT_PER_HOUR=500