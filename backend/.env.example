# ===========================================
# BACKEND CONFIGURATION - opn.onl
# ===========================================
# Copy this file to .env and fill in your values

# Database (Required)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/opn_onl

# JWT Secret (REQUIRED) - the server refuses to start unless this is set and at
# least 32 bytes long. Generate a strong one with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Configuration
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# HTTPS Redirect (set to "true" in production behind reverse proxy)
FORCE_HTTPS=false

# Trust forwarding headers for the client IP used in rate limiting and click
# analytics. Set to "true" ONLY when running behind a trusted reverse proxy
# (Cloudflare Tunnel, nginx, etc.). When false (default), the real socket peer
# IP is used and all forwarding headers are ignored — correct for direct
# exposure, but behind a proxy it collapses all visitors into one bucket.
TRUST_PROXY_HEADERS=false

# Which header the trusted edge sets to the real client IP. Default:
# cf-connecting-ip (Cloudflare sets it authoritatively; clients cannot forge
# it through Cloudflare). Set to "" to disable if not behind Cloudflare, or
# to x-real-ip if a trusted nginx overwrites that header with $remote_addr.
# REAL_IP_HEADER=cf-connecting-ip

# X-Forwarded-For fallback when REAL_IP_HEADER is unset/absent: number of
# trailing XFF entries appended by additional trusted proxies. 0 (default) =
# use the right-most entry. The first/left-most XFF entries are client-
# controlled and are never used.
# TRUSTED_PROXY_HOPS=0

# Logging
RUST_LOG=info,tower_http=debug
LOG_DIR=logs

# ===========================================
# LINK MANAGEMENT
# ===========================================

# Allow custom aliases (default: true)
ENABLE_CUSTOM_ALIASES=true

# Allow reusing slugs from deleted links (default: false)
ALLOW_DELETED_SLUG_REUSE=false

# Alias length constraints
MIN_ALIAS_LENGTH=5
MAX_ALIAS_LENGTH=25

# URL sanitization (default: true)
ENABLE_URL_SANITIZATION=true

# Abuse guards on link destinations (both default: true — recommended for any
# public instance). Independent of ENABLE_URL_SANITIZATION.
#   BLOCK_DANGEROUS_FILE_EXTENSIONS — refuse to shorten links that point directly
#     at an executable/script/installer file (.hta, .exe, .scr, .js, .msi, .jar,
#     .apk, .dmg, .iso, …). These are a common malware-delivery vector and have
#     no legitimate use behind a short link.
#   BLOCK_RAW_IP_URLS — refuse to shorten links whose host is a bare IP address
#     (no domain). Strong abuse signal on a public shortener; self-hosters who
#     legitimately shorten internal/LAN IPs can set this to false.
BLOCK_DANGEROUS_FILE_EXTENSIONS=true
BLOCK_RAW_IP_URLS=true

# Branded QR codes — brand colour, centre logo, SVG export (default: true,
# kill-switch only). When false, /links/{id}/qr serves a plain B/W PNG.
ENABLE_QR_BRANDING=true

# Burn-after-reading — one-time / self-destruct links (default: true; per-link opt-in).
ENABLE_BURN_AFTER_READING=true

# Safe-link interstitial — destination preview + reputation before redirecting,
# on opted-in links (default: true; per-link opt-in).
ENABLE_SAFE_LINK_INTERSTITIAL=true

# Smart conditional routing — device/OS/country/language + weighted A/B (default: true).
ENABLE_CONDITIONAL_ROUTING=true

# Link-in-bio — public profile page at /@username (default: true; per-user opt-in).
ENABLE_LINK_IN_BIO=true

# API keys — personal access tokens for the MCP server / API clients (default: true).
ENABLE_API_KEYS=true

# Account deletion (default: false). Note for GDPR-style compliance: if you
# keep this off, you must honor deletion requests manually (see privacy@).
ENABLE_ACCOUNT_DELETION=false

# Analytics PII retention, in days (default: 396 ≈ 13 months). A daily sweep
# anonymizes per-visitor identifiers (truncated IP, raw user agent) on click
# events older than this; aggregate analytics (country, city, device,
# browser, referrer) are kept. Set to 0 to disable the sweep entirely.
# ANALYTICS_PII_RETENTION_DAYS=396

# ===========================================
# OPTIONAL SERVICES
# ===========================================

# Redis Cache (Optional - improves redirect performance)
# REDIS_URL=redis://localhost:6379
# REDIS_CACHE_TTL=300

# Email Service (Optional - required for email verification & contact form)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_TLS=starttls  # starttls, tls, or none
# SMTP_FROM_EMAIL=noreply@opn.onl
# SMTP_FROM_NAME=opn.onl

# Admin Email (for contact form notifications)
# ADMIN_EMAIL=admin@opn.onl

# S3 Backup (Optional - for automated database backups)
# BACKUP_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# BACKUP_S3_BUCKET=opn-backups
# BACKUP_S3_ACCESS_KEY=your-access-key
# BACKUP_S3_SECRET_KEY=your-secret-key
# BACKUP_S3_REGION=auto

# Click Event Batching (Optional - tune for performance)
# CLICK_BUFFER_SIZE=100
# CLICK_FLUSH_INTERVAL=10

# ===========================================
# GeoIP Database (Optional - for location analytics)
# ===========================================
# Sign up at https://www.maxmind.com/en/geolite2/signup
# MAXMIND_ACCOUNT_ID=123456
# MAXMIND_LICENSE_KEY=your-license-key

# ===========================================
# RATE LIMITING
# ===========================================

# Global email rate limit (prevents abuse/DDoS, controls costs)
# Maximum emails that can be sent per hour (default: 500)
EMAIL_RATE_LIMIT_PER_HOUR=500
